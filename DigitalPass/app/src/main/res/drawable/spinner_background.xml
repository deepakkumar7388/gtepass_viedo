<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <!-- Background color -->
            <solid android:color="#FFFFFF" />

            <!-- Border color and width (matching Material OutlinedBox style) -->
            <stroke
                android:width="1dp"
                android:color="#757575" />

            <!-- Rounded corners -->
            <corners android:radius="12dp" />

            <!-- Padding for the text inside -->
            <padding
                android:bottom="8dp"
                android:left="12dp"
                android:right="12dp"
                android:top="8dp" />
        </shape>
    </item>
</selector>